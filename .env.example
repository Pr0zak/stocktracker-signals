# Copy to .env and fill in. Never commit the real .env.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Model tiers (see the claude-api reference for current IDs).
DEEP_MODEL=claude-opus-4-8      # on-demand single-ticker deep dive
SCAN_MODEL=claude-haiku-4-5     # cheap nightly watchlist scan

# Cache TTL for a verdict (seconds). Signals are daily — a few hours is plenty.
VERDICT_TTL_SECONDS=14400
